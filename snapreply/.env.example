# ─── Database (Supabase) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/snapreply

# ─── Meta WhatsApp Cloud API (FREE) ──────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=choose_any_string_here
WHATSAPP_BUSINESS_NUMBER=+447700000000

# ─── Twilio (SMS fallback only) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_NUMBER_POOL=+447700000001

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Stripe (3 tiers x 2 billing cycles = 6 price IDs) ───────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PRICE_ID_STARTER=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_GROWTH=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_STARTER_ANNUAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_GROWTH_ANNUAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO_ANNUAL=price_xxxxxxxxxxxxx

# ─── Resend (free tier) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
FROM_EMAIL=hello@snapreply.co.uk

# ─── Google Calendar (Growth+ tier) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_64_char_random_string_here
PRODUCTION=false
BASE_URL=http://localhost:8000

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PHONE=+447700000000
ADMIN_EMAIL=you@youremail.com
ADMIN_SECRET_TOKEN=choose_a_secret_token
